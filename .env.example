# =============================================================================
# Frontier AI Radar — Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional except at least one LLM provider key.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Options: "anthropic" | "openai" | "azure_openai"
# Use "openai" for Groq, Ollama, Gemini, or any OpenAI-compatible endpoint.
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic

# --- Anthropic Claude (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI-compatible (used when LLM_PROVIDER=openai) ---
# Supports Groq, Ollama, Gemini, vanilla OpenAI, etc.
# Uncomment and fill in one of the blocks below.

# Groq (free tier, fast — get key at console.groq.com)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_your_groq_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Ollama (local, no API key needed — run: ollama serve)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2

# Google Gemini
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_gemini_key_here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.0-flash

# --- Azure OpenAI (used when LLM_PROVIDER=azure_openai) ---
# AZURE_OPENAI_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# -----------------------------------------------------------------------------
# Email Delivery (optional — digests are saved as PDFs even without email)
# -----------------------------------------------------------------------------
# SMTP (Gmail, Brevo, or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here   # Gmail: use an App Password, not your login password
EMAIL_FROM=your_email@gmail.com
EMAIL_RECIPIENTS=you@example.com,colleague@example.com

# SendGrid (alternative to SMTP — overrides SMTP when set)
# SENDGRID_API_KEY=SG.your_sendgrid_key_here

# -----------------------------------------------------------------------------
# Storage Paths (defaults work out of the box — change only if needed)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/radar.db
DATA_DIR=./data
PDF_DIR=./data/pdfs
SNAPSHOTS_DIR=./data/snapshots

# -----------------------------------------------------------------------------
# Crawling
# -----------------------------------------------------------------------------
# Set to true to check robots.txt before crawling each domain (slower but polite)
RESPECT_ROBOTS_TXT=false

# -----------------------------------------------------------------------------
# Scheduling (Prefect cron)
# -----------------------------------------------------------------------------
# Default: 6:30 AM Pacific Time every day
RUN_SCHEDULE="30 6 * * *"
RUN_TIMEZONE=America/Los_Angeles

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
# Prefect server URL — leave commented to use local executor (no server needed)
# PREFECT_API_URL=http://localhost:4200/api

# Frontend URL — used to build dashboard deep-links in digest emails
FRONTEND_URL=http://localhost:3000
